{
  "name": "kaynos-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Kaynos help center — static documentation site",
  "scripts": {
    "serve": "npx http-server . -p 3000 -c-1",
    "test": "npx playwright test",
    "test:e2e": "npx playwright test",
    "test:ci": "BASE_URL=http://localhost:3000 npx playwright test",
    "validate:xml": "xmllint --noout feed.xml sitemap.xml",
    "validate:html": "html-validate index.html"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "html-validate": "^9.0.0",
    "http-server": "^14.1.1",
    "wait-on": "^9.0.5"
  }
}
